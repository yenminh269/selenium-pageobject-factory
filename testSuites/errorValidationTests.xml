<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite parallel="tests" name="Loan Department">
    <groups>
        <run>
            <include name="ErrorHandling"/>
        </run>
    </groups>
    <test thread-count="5" name="Standard Test">
        <classes>
            <class name="org.example.POMTest"/>
        </classes>
    </test>

    <test name="Error Validation Test">
        <classes>
            <class name="org.example.errorValidation"/>
        </classes>
    </test>
</suite>