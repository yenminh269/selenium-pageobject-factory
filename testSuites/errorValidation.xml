<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Error Validate">
    <groups>
        <run>
            <include name="ErrorHandling"/>
        </run>
    </groups>
    <listeners>
        <listener class-name="TestComponents.Listeners"/>
    </listeners>
    <test name="Error Validation Test">
        <classes>
            <class name="org.example.errorValidationTest"/>
        </classes>
    </test>
</suite>